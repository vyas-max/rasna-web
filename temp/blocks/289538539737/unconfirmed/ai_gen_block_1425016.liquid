{% doc %}
  @prompt
    Create a hero banner section with separate “Desktop” and “Mobile” media inputs (each accepts image or video) plus separate height controls for Desktop and Mobile (slider or input with px and vh options); render the correct asset per device breakpoint, apply the selected height per view, keep media centered with safe cropping controls, allow toggling between “cover” and “contain” to avoid cutting important areas, and ensure everything stacks/adjusts on small screens with no horizontal scroll.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-hero-banner__media-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    {% if block.settings.height_unit_desktop == 'px' %}
      height: {{ block.settings.height_desktop }}px;
    {% else %}
      height: {{ block.settings.height_desktop }}vh;
    {% endif %}
  }

  .ai-hero-banner__media-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.object_fit }};
    object-position: {{ block.settings.focal_point_horizontal }} {{ block.settings.focal_point_vertical }};
  }

  .ai-hero-banner__desktop-media-{{ ai_gen_id }} {
    display: block;
  }

  .ai-hero-banner__mobile-media-{{ ai_gen_id }} {
    display: none;
  }

  .ai-hero-banner__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .ai-hero-banner__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_alignment }};
    align-items: {{ block.settings.content_horizontal_alignment }};
    padding: 40px 20px;
    text-align: {{ block.settings.text_alignment }};
    z-index: 2;
  }

  .ai-hero-banner__heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px;
    max-width: 800px;
  }

  .ai-hero-banner__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    margin: 0 0 24px;
    max-width: 600px;
  }

  .ai-hero-banner__button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 14px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
  }

  .ai-hero-banner__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-hero-banner__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-hero-banner__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-banner__media-container-{{ ai_gen_id }} {
      {% if block.settings.height_unit_mobile == 'px' %}
        height: {{ block.settings.height_mobile }}px;
      {% else %}
        height: {{ block.settings.height_mobile }}vh;
      {% endif %}
    }

    .ai-hero-banner__desktop-media-{{ ai_gen_id }} {
      display: none;
    }

    .ai-hero-banner__mobile-media-{{ ai_gen_id }} {
      display: block;
    }

    .ai-hero-banner__content-{{ ai_gen_id }} {
      padding: 30px 16px;
    }

    .ai-hero-banner__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      margin-bottom: 12px;
    }

    .ai-hero-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
      margin-bottom: 20px;
    }

    .ai-hero-banner__button-{{ ai_gen_id }} {
      padding: 12px 24px;
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<hero-banner-{{ ai_gen_id }} class="ai-hero-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-banner__media-container-{{ ai_gen_id }}">
    {% if block.settings.desktop_image != blank or block.settings.desktop_video != blank %}
      <div class="ai-hero-banner__desktop-media-{{ ai_gen_id }}">
        {% if block.settings.desktop_video != blank %}
          <video
            class="ai-hero-banner__media-{{ ai_gen_id }}"
            autoplay
            muted
            loop
            playsinline
            {% if block.settings.desktop_video_poster != blank %}
              poster="{{ block.settings.desktop_video_poster | image_url: width: 2000 }}"
            {% endif %}
          >
            {% for source in block.settings.desktop_video.sources %}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {% endfor %}
          </video>
        {% elsif block.settings.desktop_image != blank %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            class="ai-hero-banner__media-{{ ai_gen_id }}"
            loading="eager"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
          >
        {% endif %}
      </div>
    {% else %}
      <div class="ai-hero-banner__desktop-media-{{ ai_gen_id }}">
        <div class="ai-hero-banner__placeholder-{{ ai_gen_id }}">
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
          <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
            Add desktop image or video
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.mobile_image != blank or block.settings.mobile_video != blank %}
      <div class="ai-hero-banner__mobile-media-{{ ai_gen_id }}">
        {% if block.settings.mobile_video != blank %}
          <video
            class="ai-hero-banner__media-{{ ai_gen_id }}"
            autoplay
            muted
            loop
            playsinline
            {% if block.settings.mobile_video_poster != blank %}
              poster="{{ block.settings.mobile_video_poster | image_url: width: 1000 }}"
            {% endif %}
          >
            {% for source in block.settings.mobile_video.sources %}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {% endfor %}
          </video>
        {% elsif block.settings.mobile_image != blank %}
          <img
            src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            class="ai-hero-banner__media-{{ ai_gen_id }}"
            loading="eager"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
          >
        {% endif %}
      </div>
    {% else %}
      <div class="ai-hero-banner__mobile-media-{{ ai_gen_id }}">
        {% if block.settings.desktop_image != blank or block.settings.desktop_video != blank %}
          {% if block.settings.desktop_video != blank %}
            <video
              class="ai-hero-banner__media-{{ ai_gen_id }}"
              autoplay
              muted
              loop
              playsinline
              {% if block.settings.desktop_video_poster != blank %}
                poster="{{ block.settings.desktop_video_poster | image_url: width: 1000 }}"
              {% endif %}
            >
              {% for source in block.settings.desktop_video.sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
            </video>
          {% elsif block.settings.desktop_image != blank %}
            <img
              src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
              alt="{{ block.settings.desktop_image.alt | escape }}"
              class="ai-hero-banner__media-{{ ai_gen_id }}"
              loading="eager"
              width="{{ block.settings.desktop_image.width }}"
              height="{{ block.settings.desktop_image.height }}"
            >
          {% endif %}
        {% else %}
          <div class="ai-hero-banner__placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-hero-banner__empty-state-{{ ai_gen_id }}">
              Add mobile image or video
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.show_overlay %}
      <div class="ai-hero-banner__overlay-{{ ai_gen_id }}"></div>
    {% endif %}

    <div class="ai-hero-banner__content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h1 class="ai-hero-banner__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h1>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-hero-banner__text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-hero-banner__button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</hero-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class HeroBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.videos = this.querySelectorAll('video');
        this.setupVideos();
      }

      setupVideos() {
        this.videos.forEach((video) => {
          video.play().catch(() => {});
        });
      }
    }

    customElements.define('hero-banner-{{ ai_gen_id }}', HeroBanner{{ ai_gen_id }});
  })();
</script>

